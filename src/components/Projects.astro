---
import { projects } from '../data/projects'
import ProjectCard from './ProjectCard.astro'
---

<section id="proyectos" class="py-20 px-4 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold mb-4 text-center">
      <span class="text-emerald-600 dark:text-emerald-400">#</span> Proyectos
    </h2>
    <p class="text-gray-500 dark:text-gray-400 text-center mb-10 max-w-lg mx-auto">
      Proyectos que muestran mi experiencia en distintas tecnologías y enfoques.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            image={project.image}
            githubUrl={project.githubUrl}
            demoUrl={project.demoUrl}
          />
        ))
      }
    </div>
  </div>
</section>
