---
import Skills from './Skills.astro'
---

<section id="sobre-mi" class="py-20 px-4">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold mb-8 text-center">
      <span class="text-emerald-600 dark:text-emerald-400">#</span> Sobre mí
    </h2>
    <div class="text-gray-600 dark:text-gray-400 space-y-4 mb-10 text-center leading-relaxed">
      <p>
        [Aquí va tu bio profesional — Agrega 2-3 líneas sobre tu experiencia,
        enfoque y lo que te apasiona como desarrollador.]
      </p>
    </div>
    <h3 class="text-xl font-semibold mb-6 text-center">Tecnologías</h3>
    <Skills />
  </div>
</section>
