---
const skills = [
  { name: 'Python', icon: '🐍' },
  { name: 'Django', icon: '🎯' },
  { name: 'GitHub', icon: '🐙' },
  { name: 'JavaScript', icon: '⚡' },
  { name: 'TypeScript', icon: '📘' },
  { name: 'React', icon: '⚛️' },
  { name: 'Tailwind CSS', icon: '🎨' },
  { name: 'Node.js', icon: '🟢' },
]
---

<div class="flex flex-wrap gap-3 justify-center">
  {
    skills.map((skill) => (
      <span class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-800 text-sm font-medium flex items-center gap-2 border border-gray-200 dark:border-gray-700">
        <span>{skill.icon}</span>
        {skill.name}
      </span>
    ))
  }
</div>
