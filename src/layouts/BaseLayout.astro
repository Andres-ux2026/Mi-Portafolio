---
import '../styles/global.css'
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/Mi-Portafolio/favicon.svg" />

    <meta name="description" content="Portafolio de Andres Moraga Triviño - Full Stack Developer" />
    <meta property="og:title" content="Andres Moraga Triviño | Full Stack Developer" />
    <meta property="og:description" content="Portafolio profesional - Construyo experiencias web rápidas y accesibles" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://andres-ux2026.github.io/Mi-Portafolio" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
            },
          },
        },
      }
    </script>
    <script is:inline>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      }
    </script>

    <title>Andres Moraga Triviño | Full Stack Developer</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 antialiased">
    <slot />
  </body>
</html>
